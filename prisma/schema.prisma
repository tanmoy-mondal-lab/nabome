// ─────────────────────────────────────────────────────────────
// NABOME — Premium Fashion E-Commerce
// Prisma Schema v1.0
// Database: PostgreSQL (Supabase)
// ─────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearchPostgres", "postgresqlExtensions"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  extensions        = [pg_trgm, uuid_ossp, pgcrypto]
  relationMode      = "foreignKeys"
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  customer
  super_admin
}

enum Gender {
  men
  women
  unisex
}

enum OrderStatus {
  pending
  confirmed
  processing
  shipped
  delivered
  cancelled
  returned
  refunded
}

enum PaymentStatus {
  pending
  paid
  failed
  refunded
}

enum DiscountType {
  percentage
  fixed
}

enum CampaignType {
  email
  banner
  popup
  discount
}

enum SectionType {
  hero_slider
  featured_collections
  new_arrivals
  categories_grid
  brand_story
  newsletter
  testimonials
  instagram_feed
  banner_promo
  product_grid
  custom_html
}

enum Visibility {
  all
  logged_in
  logged_out
}

enum MenuLocation {
  header
  footer
  mobile
  sidebar
}

enum AssetType {
  image
  video
  document
}

enum AnnouncementBarPosition {
  top
  bottom
}

// ─────────────────────────────────────────────────────────────
// AUTH MODULE
// ─────────────────────────────────────────────────────────────

// Maps 1:1 to Supabase auth.users
model Profile {
  id            String    @id @default(uuid()) @db.Uuid
  role          UserRole  @default(customer)
  email         String    @unique @db.VarChar(255) // Denormalized from auth.users for quick access
  firstName     String    @map("first_name") @db.VarChar(100)
  lastName      String?   @map("last_name") @db.VarChar(100)
  phone         String?   @db.VarChar(20)
  avatarUrl     String?   @map("avatar_url") @db.Text
  isActive      Boolean   @default(true) @map("is_active")
  emailVerified Boolean   @default(false) @map("email_verified")
  lastLoginAt   DateTime? @map("last_login_at") @db.Timestamptz
  loginCount    Int       @default(0) @map("login_count")
  preferences   Json?     @db.JsonB
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  addresses           Address[]
  wishlistItems       WishlistItem[]
  orders              Order[]
  reviews             Review[]
  cart                Cart?
  couponRedemptions   CouponRedemption[]
  orderHistoryEntries OrderStatusHistory[]
  sessions            AuthSession[]
  loginAttempts       LoginAttempt[]

  @@index([role])
  @@index([isActive])
  @@index([email])
  @@map("profiles")
}

// ─── AUTH SESSION TRACKING ───
// Tracks every active session for audit and force-logout capability.
model AuthSession {
  id           String   @id @default(uuid()) @db.Uuid
  profileId    String   @map("profile_id") @db.Uuid
  accessToken  String   @unique @map("access_token") @db.Text
  refreshToken String   @unique @map("refresh_token") @db.Text
  userAgent    String?  @map("user_agent") @db.Text
  ipAddress    String?  @map("ip_address") @db.VarChar(45)
  deviceName   String?  @map("device_name") @db.VarChar(200)
  isActive     Boolean  @default(true) @map("is_active")
  lastActiveAt DateTime @default(now()) @map("last_active_at") @db.Timestamptz
  expiresAt    DateTime @map("expires_at") @db.Timestamptz
  createdAt    DateTime @default(now()) @map("created_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)

  @@index([profileId, isActive])
  @@index([refreshToken])
  @@index([accessToken])
  @@index([expiresAt])
  @@map("auth_sessions")
}

// ─── LOGIN ATTEMPT AUDIT ───
// Records every login attempt for brute-force detection and security audit.
model LoginAttempt {
  id         String   @id @default(uuid()) @db.Uuid
  profileId  String?  @map("profile_id") @db.Uuid
  email      String   @db.VarChar(255)
  ipAddress  String   @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.Text
  success    Boolean  @default(false)
  failReason String?  @map("fail_reason") @db.VarChar(100)
  createdAt  DateTime @default(now()) @map("created_at")

  profile Profile? @relation(fields: [profileId], references: [id], onDelete: SetNull)

  @@index([email, createdAt])
  @@index([ipAddress, createdAt])
  @@index([profileId])
  @@map("login_attempts")
}

// ─────────────────────────────────────────────────────────────
// PRODUCT MODULE
// ─────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.Text
  parentId    String?  @map("parent_id") @db.Uuid
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  metaTitle   String?  @map("meta_title") @db.VarChar(200)
  metaDesc    String?  @map("meta_desc") @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  parent        Category?     @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children      Category[]    @relation("CategoryHierarchy")
  products      Product[]
  subcategories Subcategory[]
  sizeGuides    SizeGuide[]

  @@index([slug])
  @@index([parentId])
  @@index([isActive])
  @@index([sortOrder])
  @@map("categories")
}

model Subcategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  description String?  @db.Text
  imageUrl    String?  @map("image_url") @db.Text
  categoryId  String   @map("category_id") @db.Uuid
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category Category @relation(fields: [categoryId], references: [id], onDelete: Cascade, map: "subcategories_category_id_fkey")
  products Product[]

  @@index([slug])
  @@index([categoryId])
  @@index([isActive])
  @@map("subcategories")
}

model Collection {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(200)
  slug        String    @unique @db.VarChar(200)
  description String?   @db.Text
  heroImageUrl String?  @map("hero_image_url") @db.Text
  isActive    Boolean   @default(true) @map("is_active")
  isFeatured  Boolean   @default(false) @map("is_featured")
  startDate   DateTime? @map("start_date") @db.Timestamptz
  endDate     DateTime? @map("end_date") @db.Timestamptz
  sortOrder   Int       @default(0) @map("sort_order")
  metaTitle   String?   @map("meta_title") @db.VarChar(200)
  metaDesc    String?   @map("meta_desc") @db.Text
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  products Product[]

  @@index([slug])
  @@index([isFeatured])
  @@index([sortOrder])
  @@map("collections")
}

model Brand {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  description String?  @db.Text
  logoUrl     String?  @map("logo_url") @db.Text
  websiteUrl  String?  @map("website_url") @db.Text
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  products Product[]

  @@index([slug])
  @@index([isActive])
  @@map("brands")
}

model SizeGuide {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  description String?  @db.Text
  categoryId  String?  @map("category_id") @db.Uuid
  type        String   @default("clothing") @db.VarChar(50)
  unit        String   @default("inches") @db.VarChar(20)
  imageUrl    String?  @map("image_url") @db.Text
  measurements Json    @db.JsonB
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  products Product[]

  @@index([slug])
  @@index([categoryId])
  @@map("size_guides")
}

model InventoryAlert {
  id        String   @id @default(uuid()) @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  type      String   @db.VarChar(50)
  message   String   @db.Text
  threshold Int?     @db.SmallInt
  currentStock Int  @map("current_stock") @db.SmallInt
  isResolved Boolean @default(false) @map("is_resolved")
  resolvedAt DateTime? @map("resolved_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId, isResolved])
  @@index([type, isResolved])
  @@index([createdAt])
  @@map("inventory_alerts")
}

model Product {
  id               String    @id @default(uuid()) @db.Uuid
  name             String    @db.VarChar(300)
  slug             String    @unique @db.VarChar(300)
  description      String?   @db.Text
  shortDescription String?   @map("short_description") @db.Text
  categoryId       String?   @map("category_id") @db.Uuid
  subcategoryId    String?   @map("subcategory_id") @db.Uuid
  collectionId     String?   @map("collection_id") @db.Uuid
  brandId          String?   @map("brand_id") @db.Uuid
  basePrice        Decimal   @map("base_price") @db.Decimal(10, 2)
  compareAtPrice   Decimal?  @map("compare_at_price") @db.Decimal(10, 2)
  costPrice        Decimal?  @map("cost_price") @db.Decimal(10, 2)
  salePrice        Decimal?  @map("sale_price") @db.Decimal(10, 2)
  discountPercent  Int?      @map("discount_percent") @db.SmallInt
  currency         String    @default("INR") @db.VarChar(3)
  material         String?   @db.VarChar(200)
  careInstructions String?   @map("care_instructions") @db.Text
  sizeChartUrl     String?   @map("size_chart_url") @db.Text
  sizeGuideId      String?   @map("size_guide_id") @db.Uuid
  isActive         Boolean   @default(true) @map("is_active")
  isFeatured       Boolean   @default(false) @map("is_featured")
  isNew            Boolean   @default(false) @map("is_new")
  gender           Gender    @default(unisex)
  sortOrder        Int       @default(0) @map("sort_order")
  publishedAt      DateTime? @map("published_at") @db.Timestamptz
  scheduledPublishAt DateTime? @map("scheduled_publish_at") @db.Timestamptz
  scheduledArchiveAt DateTime? @map("scheduled_archive_at") @db.Timestamptz
  metaTitle        String?   @map("meta_title") @db.VarChar(200)
  metaDesc         String?   @map("meta_desc") @db.Text
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  category    Category?    @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id], onDelete: SetNull)
  collection  Collection?  @relation(fields: [collectionId], references: [id], onDelete: SetNull)
  brand       Brand?       @relation(fields: [brandId], references: [id], onDelete: SetNull)
  sizeGuide   SizeGuide?   @relation(fields: [sizeGuideId], references: [id], onDelete: SetNull)

  variants      ProductVariant[]
  images        ProductImage[]
  attributes    ProductAttribute[]
  productTags   ProductTagOnProduct[]
  productLabels ProductLabelOnProduct[]
  relatedTo     RelatedProduct[] @relation("RelatedProductSource")
  relatedFrom   RelatedProduct[] @relation("RelatedProductTarget")
  reviews       Review[]
  orderItems    OrderItem[]
  lookbookItems LookbookItem[]

  @@index([slug])
  @@index([categoryId])
  @@index([collectionId])
  @@index([gender])
  @@index([brandId])
  @@index([isActive, isFeatured])
  @@index([isActive, isNew])
  @@index([basePrice])
  @@index([scheduledPublishAt])
  @@index([scheduledArchiveAt])
  @@index([createdAt])
  @@map("products")
}

model ProductVariant {
  id              String   @id @default(uuid()) @db.Uuid
  productId       String   @map("product_id") @db.Uuid
  sku             String   @unique @db.VarChar(100)
  size            String   @db.VarChar(50)
  color           String   @db.VarChar(100)
  colorHex        String?  @map("color_hex") @db.VarChar(7)
  priceAdjustment Decimal  @default(0) @map("price_adjustment") @db.Decimal(10, 2)
  stock           Int      @default(0)
  reservedStock   Int      @default(0) @map("reserved_stock")
  weight          Decimal? @db.Decimal(8, 2)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  product        Product            @relation(fields: [productId], references: [id], onDelete: Cascade)
  images         ProductImage[]
  cartItems      CartItem[]
  wishlistItems  WishlistItem[]
  orderItems     OrderItem[]
  inventoryMovements InventoryMovement[]
  inventoryAlerts    InventoryAlert[]

  @@index([productId])
  @@index([sku])
  @@index([size, color])
  @@index([isActive])
  @@map("product_variants")
}

model ProductImage {
  id        String  @id @default(uuid()) @db.Uuid
  productId String  @map("product_id") @db.Uuid
  variantId String? @map("variant_id") @db.Uuid
  url       String  @db.Text
  altText   String? @map("alt_text") @db.VarChar(500)
  sortOrder Int     @default(0) @map("sort_order")
  isPrimary Boolean @default(false) @map("is_primary")

  product Product         @relation(fields: [productId], references: [id], onDelete: Cascade)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([productId])
  @@index([variantId])
  @@index([isPrimary])
  @@map("product_images")
}

model ProductAttribute {
  id        String @id @default(uuid()) @db.Uuid
  productId String @map("product_id") @db.Uuid
  name      String @db.VarChar(100)
  value     String @db.VarChar(200)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
  @@index([name])
  @@map("product_attributes")
}

model RelatedProduct {
  id         String   @id @default(uuid()) @db.Uuid
  sourceId   String   @map("source_id") @db.Uuid
  targetId   String   @map("target_id") @db.Uuid
  type       String   @default("related") @db.VarChar(50)
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  source Product @relation("RelatedProductSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target Product @relation("RelatedProductTarget", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId, type])
  @@index([sourceId, type])
  @@index([targetId, type])
  @@map("related_products")
}

model ProductTag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  slug      String   @unique @db.VarChar(200)
  createdAt DateTime @default(now()) @map("created_at")

  products ProductTagOnProduct[]

  @@index([slug])
  @@map("product_tags")
}

model ProductTagOnProduct {
  productId String @map("product_id") @db.Uuid
  tagId     String @map("tag_id") @db.Uuid

  product Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  tag     ProductTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([productId, tagId])
  @@map("product_tags_products")
}

model ProductLabel {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(100)
  slug      String   @unique @db.VarChar(200)
  color     String?  @db.VarChar(7)
  createdAt DateTime @default(now()) @map("created_at")

  products ProductLabelOnProduct[]

  @@index([slug])
  @@map("product_labels")
}

model ProductLabelOnProduct {
  productId String @map("product_id") @db.Uuid
  labelId   String @map("label_id") @db.Uuid

  product Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  label   ProductLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@id([productId, labelId])
  @@map("product_labels_products")
}

model InventoryMovement {
  id             String   @id @default(uuid()) @db.Uuid
  variantId      String   @map("variant_id") @db.Uuid
  quantityChange Int      @map("quantity_change")
  stockAfter     Int      @map("stock_after")
  reason         String   @db.VarChar(200)
  referenceId    String?  @map("reference_id") @db.VarChar(100)
  note           String?  @db.Text
  createdAt      DateTime @default(now()) @map("created_at")

  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([createdAt])
  @@index([reason])
  @@map("inventory_movements")
}

// ─────────────────────────────────────────────────────────────
// CUSTOMER MODULE
// ─────────────────────────────────────────────────────────────

model Address {
  id        String  @id @default(uuid()) @db.Uuid
  profileId String  @map("profile_id") @db.Uuid
  label     String  @default("Home") @db.VarChar(50)
  fullName  String  @map("full_name") @db.VarChar(200)
  phone     String  @db.VarChar(20)
  line1     String  @db.VarChar(500)
  line2     String? @db.VarChar(500)
  city      String  @db.VarChar(200)
  state     String  @db.VarChar(200)
  pincode   String  @db.VarChar(10)
  country   String  @default("India") @db.VarChar(100)
  isDefault Boolean @default(false) @map("is_default")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  ordersAsShipping Order[] @relation("ShippingAddress")
  ordersAsBilling  Order[] @relation("BillingAddress")

  @@index([profileId])
  @@index([pincode])
  @@map("addresses")
}

model WishlistItem {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @map("profile_id") @db.Uuid
  variantId String   @map("variant_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  profile Profile        @relation(fields: [profileId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([profileId, variantId])
  @@index([profileId])
  @@map("wishlist_items")
}

// ─────────────────────────────────────────────────────────────
// CART MODULE
// ─────────────────────────────────────────────────────────────

model Cart {
  id        String   @id @default(uuid()) @db.Uuid
  profileId String   @unique @map("profile_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  profile Profile    @relation(fields: [profileId], references: [id], onDelete: Cascade)
  items   CartItem[]

  @@map("carts")
}

model CartItem {
  id             String  @id @default(uuid()) @db.Uuid
  cartId         String  @map("cart_id") @db.Uuid
  variantId      String  @map("variant_id") @db.Uuid
  quantity       Int     @default(1)
  savedForLater  Boolean @default(false) @map("saved_for_later")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  cart    Cart           @relation(fields: [cartId], references: [id], onDelete: Cascade)
  variant ProductVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([cartId, variantId])
  @@index([cartId])
  @@map("cart_items")
}

// ─────────────────────────────────────────────────────────────
// ORDER MODULE
// ─────────────────────────────────────────────────────────────

model Order {
  id              String        @id @default(uuid()) @db.Uuid
  orderNumber     String        @unique @map("order_number") @db.VarChar(50)
  profileId       String?       @map("profile_id") @db.Uuid
  email           String        @db.VarChar(255)
  status          OrderStatus   @default(pending)
  subtotal        Decimal       @db.Decimal(10, 2)
  shippingCost    Decimal       @default(0) @map("shipping_cost") @db.Decimal(10, 2)
  tax             Decimal       @default(0) @db.Decimal(10, 2)
  discount        Decimal       @default(0) @db.Decimal(10, 2)
  couponCode      String?       @map("coupon_code") @db.VarChar(50)
  total           Decimal       @db.Decimal(10, 2)
  currency        String        @default("INR") @db.VarChar(3)
  paymentMethod   String        @map("payment_method") @db.VarChar(50)
  paymentStatus   PaymentStatus @default(pending) @map("payment_status")
  razorpayOrderId   String?     @map("razorpay_order_id") @db.VarChar(100)
  razorpayPaymentId String?     @map("razorpay_payment_id") @db.VarChar(100)
  shippingAddressId String?     @map("shipping_address_id") @db.Uuid
  billingAddressId  String?     @map("billing_address_id") @db.Uuid
  giftMessage     String?       @map("gift_message") @db.Text
  notes           String?       @db.Text
  shippedAt       DateTime?     @map("shipped_at") @db.Timestamptz
  deliveredAt     DateTime?     @map("delivered_at") @db.Timestamptz
  cancelledAt     DateTime?     @map("cancelled_at") @db.Timestamptz
  refundedAt      DateTime?     @map("refunded_at") @db.Timestamptz
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  profile      Profile?    @relation(fields: [profileId], references: [id], onDelete: SetNull)
  shippingAddress Address? @relation("ShippingAddress", fields: [shippingAddressId], references: [id], onDelete: SetNull)
  billingAddress  Address? @relation("BillingAddress", fields: [billingAddressId], references: [id], onDelete: SetNull)

  items            OrderItem[]
  statusHistory    OrderStatusHistory[]
  couponRedemption CouponRedemption?

  @@index([orderNumber])
  @@index([profileId])
  @@index([email])
  @@index([status])
  @@index([paymentStatus])
  @@index([createdAt])
  @@map("orders")
}

model OrderItem {
  id           String  @id @default(uuid()) @db.Uuid
  orderId      String  @map("order_id") @db.Uuid
  productId    String  @map("product_id") @db.Uuid
  variantId    String? @map("variant_id") @db.Uuid
  productName  String  @map("product_name") @db.VarChar(300)
  variantLabel String  @map("variant_label") @db.VarChar(200)
  sku          String  @db.VarChar(100)
  quantity     Int
  unitPrice    Decimal @map("unit_price") @db.Decimal(10, 2)
  totalPrice   Decimal @map("total_price") @db.Decimal(10, 2)
  imageUrl     String? @map("image_url") @db.Text

  order   Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product         @relation(fields: [productId], references: [id], onDelete: Restrict)
  variant ProductVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}

model OrderStatusHistory {
  id        String      @id @default(uuid()) @db.Uuid
  orderId   String      @map("order_id") @db.Uuid
  status    OrderStatus
  note      String?     @db.Text
  createdBy String?     @map("created_by") @db.Uuid
  createdAt DateTime    @default(now()) @map("created_at")

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  creator Profile? @relation(fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([createdAt])
  @@map("order_status_history")
}

