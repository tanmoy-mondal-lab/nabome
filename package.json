    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "framer-motion": "^12.9.2",
    "lucide-react": "^0.510.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-helmet-async": "^3.0.0",
    "react-hook-form": "^7.55.0",
    "react-router-dom": "^7.5.0",
