# Supabase — get these from https://supabase.com (Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin — the email you use to log in (only this user can manage products)
VITE_ADMIN_EMAIL=your-email@example.com

# Google Analytics measurement ID (optional)
VITE_GA_ID=G-T0HLCQE1B9

# Brevo (Sendinblue) — for transactional order confirmation emails
# Get API key at https://app.brevo.com/settings/keys/smtp
# Free tier: 300 emails/day
VITE_BREVO_API_KEY=your-brevo-api-key-here

# Optional: override sender email (defaults to VITE_ADMIN_EMAIL)
# VITE_BREVO_SENDER_EMAIL=orders@yourdomain.com
