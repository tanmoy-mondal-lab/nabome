# ─── SUPABASE ──────────────────────────────────────────
# Get these from https://supabase.com (Project Settings > API)
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── CLOUDINARY ────────────────────────────────────────
# Get these from https://cloudinary.com (Dashboard)
VITE_CLOUDINARY_CLOUD_NAME=your-cloud-name
VITE_CLOUDINARY_UPLOAD_PRESET=your-upload-preset

# ─── ADMIN ─────────────────────────────────────────────
# The email you use to log in as admin
VITE_ADMIN_EMAIL=your-email@example.com

# ─── GOOGLE ANALYTICS ──────────────────────────────────
# Google Analytics 4 measurement ID (optional)
VITE_GA_ID=G-T0HLCQE1B9

# ─── BREVO (SENDINBLUE) ───────────────────────────────
# For transactional order confirmation emails
# Get API key at https://app.brevo.com/settings/keys/smtp
# Free tier: 300 emails/day
VITE_BREVO_API_KEY=your-brevo-api-key-here

# Optional: override sender email (defaults to nabome.official@gmail.com)
# VITE_BREVO_SENDER_EMAIL=orders@yourdomain.com

# ─── WHATSAPP ──────────────────────────────────────────
# WhatsApp sender number for password reset via WhatsApp (optional)
# Must be a Brevo-approved WhatsApp Business number with + prefix
# VITE_WHATSAPP_SENDER=+919163854706

# ─── SUPABASE SERVICE ROLE (SERVER-SIDE ONLY) ─────────
# For password reset via API (generate + send new password)
# Get it from Supabase: Project Settings > API > service_role key
# WARNING: never expose this on the client; only used server-side by /api routes
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
