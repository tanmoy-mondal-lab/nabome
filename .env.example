# =============================================================================
# নবME — Environment Variables
# Copy this to .env and fill in the values
# =============================================================================
#
# REQUIRED (22 variables):
#
# Frontend (Vite) — exposed to client:
#   VITE_SUPABASE_URL, VITE_SUPABASE_ANON_KEY, VITE_RAZORPAY_KEY_ID,
#   VITE_CLOUDINARY_CLOUD_NAME, VITE_SITE_URL
#
# Backend — server-only:
#   DATABASE_URL, DATABASE_URL_POOLED, SUPABASE_URL,
#   SUPABASE_SERVICE_ROLE_KEY, SUPABASE_ANON_KEY, RAZORPAY_KEY_ID,
#   RAZORPAY_KEY_SECRET, RAZORPAY_WEBHOOK_SECRET, CLOUDINARY_CLOUD_NAME,
#   CLOUDINARY_UPLOAD_PRESET, RESEND_API_KEY, EMAIL_FROM, ADMIN_EMAILS,
#   SITE_URL
#
# Optional:
#   VITE_GA_ID (Google Analytics 4), VITE_TURNSTILE_SITE_KEY,
#   TURNSTILE_SECRET_KEY
# =============================================================================

# ─── Frontend (Vite) ───
# These are exposed to the browser. Must start with VITE_.
VITE_SUPABASE_URL=https://ddfclkgkveprnxyjhjlb.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
VITE_RAZORPAY_KEY_ID=rzp_live_...
VITE_CLOUDINARY_CLOUD_NAME=dmzbh87bi
VITE_CLOUDINARY_UPLOAD_PRESET=nabome_uploads
VITE_SITE_URL=https://www.nabome.online
VITE_GA_ID=G-T0HLCQE1B9

# ─── Database (Supabase/Neon PostgreSQL) ───
# Direct connection (for migrations/studio):
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.ddfclkgkveprnxyjhjlb.supabase.co:5432/postgres"
# Pooled connection (for production API — serverless):
# Replace [REGION] with your Supabase pooler region (e.g., ap-south-1)
DATABASE_URL_POOLED="postgresql://postgres:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# ─── Supabase Auth ───
SUPABASE_URL=https://ddfclkgkveprnxyjhjlb.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...  # From Dashboard → API → service_role
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...          # Same as VITE_SUPABASE_ANON_KEY
SITE_URL=https://www.nabome.online

# ─── Razorpay ───
# IMPORTANT: Set REAL live keys in Cloudflare Pages project settings (not in .env)
# Live keys: Razorpay Dashboard → Settings → API Keys → Switch to Live → Copy
# WARNING: Placeholder values will cause payment failures in production
RAZORPAY_KEY_ID=rzp_live_YOUR_ACTUAL_KEY_ID
RAZORPAY_KEY_SECRET=YOUR_ACTUAL_KEY_SECRET
# Webhook secret (must match Razorpay Dashboard → Settings → Webhooks)
RAZORPAY_WEBHOOK_SECRET=YOUR_ACTUAL_WEBHOOK_SECRET

# ─── Resend (Email) ───
RESEND_API_KEY=re_...              # Resend Dashboard → API Keys
EMAIL_FROM=nabome@nabome.online     # Must be verified in Resend
ADMIN_EMAILS=admin@nabome.online    # Comma-separated

# ─── Cloudinary (Image CDN) ───
CLOUDINARY_CLOUD_NAME=dmzbh87bi
CLOUDINARY_API_KEY=           # Only needed for signed uploads
CLOUDINARY_API_SECRET=        # Only needed for signed uploads
CLOUDINARY_UPLOAD_PRESET=nabome_uploads

# ─── Turnstile (Bot Protection) ───
# Get keys from Cloudflare Dashboard → Turnstile → Add Widget
VITE_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...
